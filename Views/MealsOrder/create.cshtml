@model Young_snakes.Models.PersonMeal

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="registration-card shadow-sm">
                <h2 class="fw-bold text-uppercase">Meal Order</h2>
                <p class="text-muted small">
                    Registering meal for: 
                    <strong>@ViewBag.PlayerName</strong>
                    \</p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="IdPerson" />
                    <div class="form-group mb-4 mt-4">
                        <label class="form-label text-uppercase small fw-bold">Select Dish</label>
                        <select asp-for="IdMeal" class="form-control form-control-lg" asp-items="ViewBag.IdMeal">
                            <option value="">-- Choose from Menu --</option>
                        </select>
                        <span asp-validation-for="IdMeal" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <input asp-for="MealDate" class="form-control" type="datetime-local" />
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-primary-hockey py-3">Confirm & Register Expense</button>
                        <a asp-controller="Teams" asp-action="Dashboard" class="btn btn-light text-muted">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>