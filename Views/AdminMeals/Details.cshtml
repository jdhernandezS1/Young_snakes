@model Young_snakes.Models.Meal

@{
    ViewData["Title"] = "Dettagli Pasto";
}

<div class="container py-5">
    <div class="row justify-content-center text-dark">
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-dark p-5 text-center text-white">
                    <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-info-circle-fill fs-1 text-white"></i>
                    </div>
                    <h3 class="fw-bold m-0">@Model.MealName</h3>
                    <span class="text-white-50 small text-uppercase tracking-wider">Identificativo pasto: #@Model.IdMeal</span>
                </div>
                <div class="card-body p-5 bg-white text-center">
                    <label class="small text-muted text-uppercase fw-bold d-block mb-2">Prezzo di Vendita</label>
                    <h1 class="display-4 fw-bold text-primary mb-0">CHF @Model.Price.ToString("F2")</h1>
                    
                    <hr class="my-5 opacity-25">
                    
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Edit" asp-route-id="@Model.IdMeal" class="btn btn-dark px-4 rounded-pill">
                            <i class="bi bi-pencil me-2"></i>Modifica
                        </a>
                        <a asp-action="Index" class="btn btn-light border px-4 rounded-pill">
                            <i class="bi bi-arrow-left me-2"></i>Lista
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>