@model Young_snakes.Models.Meal

@{
    ViewData["Title"] = "Elimina Pasto";
}

<div class="container py-5">
    <div class="row justify-content-center text-dark">
        <div class="col-lg-5 text-center">
            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                <i class="bi bi-trash3-fill fs-1"></i>
            </div>
            
            <h2 class="fw-bold mb-3">Sei sicuro?</h2>
            <p class="text-muted mb-5">Stai per eliminare il pasto <strong>@Model.MealName</strong>. Questa azione non può essere annullata.</p>

            <div class="card border-0 bg-light rounded-4 p-4 mb-5 shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted fw-bold text-uppercase small">Costo totale</span>
                    <span class="h4 fw-bold mb-0 text-danger">CHF: @Model.Price.ToString("F2")</span>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="IdMeal" />
                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm py-3 text-uppercase fs-6">
                        Conferma Eliminazione
                    </button>
                    <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none fw-bold">
                        No, annulla e torna indietro
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>