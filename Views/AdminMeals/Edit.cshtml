@model Young_snakes.Models.Meal

@{
    ViewData["Title"] = "Modifica Pasto";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                <h2 class="fw-light m-0">Modifica <span class="fw-bold">Pasto</span></h2>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Indietro</a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="IdMeal" />
                    <div class="bg-dark p-4 p-md-5 text-white">
                        <label asp-for="MealName" class="small text-uppercase fw-bold text-white-50 d-block mb-2">Nome Pasto</label>
                        <input asp-for="MealName" class="form-control form-control-lg bg-white border-0 shadow-none text-dark fw-bold" />
                        <span asp-validation-for="MealName" class="text-danger small"></span>
                    </div>

                    <div class="card-body p-4 p-md-5 bg-white text-dark">
                        <div class="mb-4">
                            <label asp-for="Price" class="form-label small text-muted text-uppercase fw-bold">Prezzo Aggiornato (CHF)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-0 text-muted"> </span>
                                <input asp-for="Price" class="form-control bg-light border-0 shadow-none fw-bold" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold py-3 text-uppercase fs-6">
                                Salva Cambiamenti
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>