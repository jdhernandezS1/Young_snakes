@model IEnumerable<Young_snakes.Models.Meal>

@{
    ViewData["Title"] = "Gestione Pasti";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h1 class="fw-light m-0">Menù <span class="fw-bold">Pasti</span></h1>
            <p class="text-muted small mb-0">Configura le opzioni e i prezzi del servizio catering</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Aggiungi Pasto
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 small text-uppercase fw-bold text-muted">Descrizione Pasto</th>
                        <th class="py-3 border-0 small text-uppercase fw-bold text-muted text-center">Prezzo Unitario</th>
                        <th class="pe-4 py-3 border-0 small text-uppercase fw-bold text-muted text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3">
                                        <i class="bi bi-egg-fried fs-5"></i>
                                    </div>
                                    <span class="fw-bold text-dark">@item.MealName</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fw-bold">
                                    CHF @item.Price.ToString("F2")
                                </span>
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group btn-group-sm shadow-none">
                                    <a asp-action="Edit" asp-route-id="@item.IdMeal" class="btn btn-white border-0 text-primary" title="Modifica">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.IdMeal" class="btn btn-white border-0 text-secondary" title="Dettagli">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.IdMeal" class="btn btn-white border-0 text-danger" title="Elimina">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>