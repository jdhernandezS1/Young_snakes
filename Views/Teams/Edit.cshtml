@model Team

@{
    ViewData["Title"] = "Modifica Team";
}

<h1>✏️ Modifica Team</h1>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            
            <input type="hidden" asp-for="IdTeam" />

            <!-- Nasconde IdUser -->
            
            <div class="form-group">
                <label asp-for="TeamName">Nome Team</label>
                <input asp-for="TeamName" class="form-control" />
                <span asp-validation-for="TeamName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="City">Città</label>
                <input asp-for="City" class="form-control" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Country">Paese</label>
                <input asp-for="Country" class="form-control" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClubColors">Colori</label>
                <input asp-for="ClubColors" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="ArrivalDateBellinzona">Data Arrivo</label>
                <input asp-for="ArrivalDateBellinzona" type="date" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="TeamImageUrl">Immagine URL</label>
                <input asp-for="TeamImageUrl" class="form-control" />
            </div>

            <!--  TOURNAMENT -->
            <div class="form-group">
                <label>Torneo</label>
                <select asp-for="IdTournament" class="form-control"
                        asp-items="@(new SelectList(ViewBag.Tournaments, "IdTournament", "TournamentName", Model.IdTournament))">
                    <option value="">-- Seleziona Torneo --</option>
                </select>
                <span asp-validation-for="IdTournament" class="text-danger"></span>
            </div>

            <!--  MEZZO -->
            <div class="form-group">
                <label>Trasporto</label>
                <select asp-for="IdMezzo" class="form-control"
                        asp-items="@(new SelectList(ViewBag.Mezzos, "IdMezzo", "Veicolo", Model.IdMezzo))">
                    <option value="">-- Seleziona --</option>
                </select>
            </div>

            <!--  ACCOMMODATION -->
            <div class="form-group">
                <label>Alloggio</label>
                <select asp-for="IdAccommodation" class="form-control"
                        asp-items="@(new SelectList(ViewBag.Accommodations, "IdAccommodation", "AccommodationName", Model.IdAccommodation))">
                    <option value="">-- Seleziona --</option>
                </select>
            </div>

            <br />

            <button type="submit" class="btn btn-primary">💾 Salva</button>
            <a asp-action="MyTeam" class="btn btn-secondary">❌ Annulla</a>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}