<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Young_snakes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
</head>
<body>
    <header class="mb-4">
        <nav class="navbar navbar-expand-lg navbar-dark navbar-hockey shadow-sm">

            <div class="container-fluid">

                <!-- BRAND -->
                <a class="navbar-brand brand-hockey" asp-controller="Home" asp-action="Index">
                    <span class="brand-y">Y</span>
                    <span class="brand-snakes">SNAKES</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 nav-hockey">

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("SuperAdmin"))
                            {                           
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminTournaments" asp-action="Index">
                                        Tornei
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminDietaryTags" asp-action="Index">
                                        Diete
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminMeals" asp-action="Index">
                                        Pasti
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminMezzoes" asp-action="Index">
                                        Mezzi
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminUsers" asp-action="Index">
                                        Utenti
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminPersonRoles" asp-action="Index">
                                        Ruoli integranti
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminTeamExpenses" asp-action="Index">
                                        Costi
                                    </a>
                                </li>
                                
                            }

                            @if (User.IsInRole("TeamUser"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Teams" asp-action="Dashboard">
                                        My Team
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- RIGHT MENU -->
                    <ul class="navbar-nav ms-auto align-items-center">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3">
                                <span class="user-tag">
                                   @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item me-2">
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-hockey-outline">
                                        Logout
                                    </button>
                                </form>
                            </li>

                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-hockey" asp-controller="Auth" asp-action="Register">
                                        Register
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-hockey-outline" asp-controller="Auth" asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Young_snakes - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>