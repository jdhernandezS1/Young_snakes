<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Young_snakes</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Young_snakes.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm"
             style="background: linear-gradient(90deg, #000000 0%, #2b2b2b 50%, #8B0000 100%);">

            <div class="container-fluid">

                <!-- BRAND -->
                <a class="navbar-brand fw-bold text-danger" asp-controller="Home" asp-action="Index">
                    Young_snakes
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Admin" asp-action="Dashboard">
                                        Admin Dashboard
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Team" asp-action="Index">
                                        Manage Teams
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("TeamUser"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Team" asp-action="MyTeam">
                                        My Team
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- RIGHT MENU -->
                    <ul class="navbar-nav ms-auto">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="text-light fw-semibold">
                                    👤 @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Logout
                                    </button>
                                </form>
                            </li>
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-sm btn-danger" asp-controller="Auth" asp-action="Register">
                                        Register
                                    </a>
                                </li>
                            }

                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-sm btn-outline-light" asp-controller="Auth" asp-action="Login">
                                    Login
                                </a>
                            </li>

                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Young_snakes - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>