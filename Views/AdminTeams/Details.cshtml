@model Team

@{
    ViewData["Title"] = "Dettagli Squadra";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-0">@Model.TeamName</h1>
            <p class="text-muted fs-5 m-0">
                <i class="bi bi-geo-alt-fill text-danger"></i> @Model.City, @Model.Country
            </p>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-action="Edit" asp-route-id="@Model?.IdTeam" class="btn btn-dark px-4">
                <i class="bi bi-pencil-square me-2"></i>Modifica
            </a>
            <a asp-action="Index" asp-route-id="@Model?.IdTournament" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left me-2"></i>Indietro
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-uppercase small tracking-wider text-primary">
                        <i class="bi bi-info-circle-fill me-2"></i>Informazioni Tecniche
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold d-block">Colori Sociali</label>
                            <div class="d-flex align-items-center mt-1">
                                <i class="bi bi-palette me-2 text-secondary"></i>
                                <span class="fs-5 fw-semibold">@Html.DisplayFor(model => model.ClubColors)</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold d-block">Data Arrivo</label>
                            <div class="d-flex align-items-center mt-1">
                                <i class="bi bi-calendar-check me-2 text-secondary"></i>
                                <span class="fs-5 fw-semibold">@Model.ArrivalDateBellinzona?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>
                        
                        <div class="col-12">
                            <hr class="opacity-25">
                        </div>

                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold d-block">Responsabile</label>
                            <div class="p-2 bg-light rounded-3 mt-1">
                                <i class="bi bi-person-badge me-2"></i> @Model.User?.UserName
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold d-block">Torneo</label>
                            <div class="p-2 bg-light rounded-3 mt-1">
                                <i class="bi bi-trophy me-2"></i> @Model.Tournament.TournamentName
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3">
                        <h6 class="fw-bold mb-3">Logistica</h6>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted">Mezzo di Trasporto</span>
                                <span class="fw-bold">ID: @Model.IdMezzo</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted">Alloggio</span>
                                <span class="fw-bold">ID: @Model.IdAccommodation</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                @if (!string.IsNullOrEmpty(Model.TeamImageUrl))
                {
                    <img src="@Model.TeamImageUrl" class="card-img-top" style="height: 250px; object-fit: cover;" alt="Logo Squadra" />
                }
                else
                {
                    <div class="bg-light d-flex flex-column align-items-center justify-content-center" style="height: 250px;">
                        <i class="bi bi-image text-muted display-1"></i>
                        <p class="text-muted small">Nessuna immagine disponibile</p>
                    </div>
                }
               
            </div>

            <div class="card border-0 shadow-lg rounded-4 bg-dark text-white overflow-hidden">
    <div class="card-body p-4">
        <div class="row align-items-center g-0">
            
            <div class="col-auto pe-4 d-none d-md-block">
                <div class="bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                    <i class="bi bi-people-fill fs-2 text-primary"></i>
                </div>
            </div>

            <div class="col">
                <div class="mb-2">
                    <span class="text-uppercase fw-bold text-white-50" style="font-size: 0.75rem; letter-spacing: 0.05rem;">
                        Stato della squadra
                    </span>
                </div>
                
                @if ((int)ViewData["RaggiuntoMinimo"] == 1)
                {
                    <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success rounded-3 m-0 py-3 px-4 shadow-sm">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold text-uppercase small mb-1">Idoneo</div>
                                <div class="small opacity-90">
                                    Hai raggiunto il minimo di <strong>@ViewData["MinPlayers"]</strong> giocatori. (Totale: @ViewData["Quantita"])
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger rounded-3 m-0 py-3 px-4 shadow-sm">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold text-uppercase small mb-1">Incompleto</div>
                                <div class="small opacity-90">
                                    Mancano giocatori per il minimo di <strong>@ViewData["MinPlayers"]</strong>. (Attuali: @ViewData["Quantita"])
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>                
        </div>
    </div>
</div>