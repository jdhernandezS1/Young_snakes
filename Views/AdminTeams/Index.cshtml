@model IEnumerable<Team>

@{
    ViewData["Title"] = "Gestione Squadre - " + ViewBag.TournamentName;
}

<div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center bg-dark text-white rounded">
        <div>
            <h2 class="m-0"><i class="bi bi-trophy"></i> @ViewBag.TournamentName</h2>
            <p class="m-0 opacity-75">Gestione delle squadre registrate</p>
        </div>
        <div class="btn-group">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Crea Squadra
            </a>
            <a asp-controller="AdminReports" asp-action="TournamentRosterPdf" 
               asp-route-id="@ViewBag.TournamentId" class="btn btn-danger">
               <i class="bi bi-file-pdf"></i> Report Torneo
            </a>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle border">
        <thead class="table-light">
            <tr>
                <th>Dettagli Squadra</th>
                <th>Località</th>
                <th style="min-width: 250px;">Riepilogo Staff e Giocatori</th>
                <th class="text-center">Azioni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold fs-5 text-dark">@item.TeamName</div>
                        <small class="text-muted">Responsabile: @item.User?.UserName</small>
                    </td>
                    <td>
                        <div><i class="bi bi-geo-alt"></i> @item.City</div>
                        <div class="text-muted small">@item.Country</div>
                    </td>
                    <td>
                        @{
                            // Logica di conteggio tramite LINQ
                            var total = item.Persons.Count();
                            var players = item.Persons.Count(p => p.Role?.RoleName.ToLower() == "player");
                            var coaches = item.Persons.Count(p => p.Role?.RoleName.ToLower().Contains("coach") == true);
                            var managers = item.Persons.Count(p => p.Role?.RoleName.ToLower().Contains("manager") == true);
                            var assistants = item.Persons.Count(p => p.Role?.RoleName.ToLower().Contains("assistant") == true);
                        }

                        @if (total > 0)
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill bg-primary px-3">
                                    @players Giocatori
                                </span>
                                
                                @if (coaches > 0)
                                {
                                    <span class="badge rounded-pill bg-danger px-3">
                                        @coaches Allenatore/i
                                    </span>
                                }
                                
                                @if (assistants > 0)
                                {
                                    <span class="badge rounded-pill bg-warning text-dark px-3">
                                        @assistants Assistente/i
                                    </span>
                                }

                                @if (managers > 0)
                                {
                                    <span class="badge rounded-pill bg-info text-dark px-3">
                                        @managers Manager
                                    </span>
                                }
                            </div>
                            <div class="mt-2 small text-muted">
                                <strong>Totale:</strong> @total membri registrati
                            </div>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Nessun membro assegnato</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="btn-group shadow-sm">
                            <a asp-action="Details" asp-route-id="@item.IdTeam" class="btn btn-sm btn-outline-secondary" title="Dettagli">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.IdTeam" class="btn btn-sm btn-outline-primary" title="Modifica Squadra">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-controller="AdminReports" asp-action="TeamRosterPdf" 
                               asp-route-id="@item.IdTeam" class="btn btn-sm btn-outline-danger" title="Scarica PDF">
                               <i class="bi bi-file-pdf"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.IdTeam" class="btn btn-sm btn-danger" title="Elimina">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>