@model Team

@{
    ViewData["Title"] = "Elimina Squadra";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="bg-danger py-4 text-center text-white">
                    <i class="bi bi-exclamation-octagon display-4"></i>
                    <h3 class="mt-2 fw-bold">Sei sicuro?</h3>
                    <p class="mb-0 opacity-75">Questa azione non può essere annullata.</p>
                </div>

                <div class="card-body p-4">
                    <p class="text-center text-muted mb-4">Stai per eliminare definitivamente la squadra:</p>
                    <h2 class="text-center fw-bold mb-4">@Model.TeamName</h2>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <div class="row g-2 small">
                            <div class="col-6 text-muted">Città:</div>
                            <div class="col-6 fw-bold text-end">@Model.City</div>
                            
                            <div class="col-6 text-muted">Nazione:</div>
                            <div class="col-6 fw-bold text-end">@Model.Country</div>
                            
                            <div class="col-6 text-muted">Responsabile ID:</div>
                            <div class="col-6 fw-bold text-end text-truncate">@Model.User?.Id</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="IdTeam" />
                        <div class="row g-2">
                            <div class="col-8">
                                <button type="submit" class="btn btn-danger btn-lg w-100 shadow-sm">
                                    <i class="bi bi-trash"></i> Sì, Elimina Squadra
                                </button>
                            </div>
                            <div class="col-4">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">No</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>