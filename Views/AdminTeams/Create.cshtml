@model Team

@{
    ViewData["Title"] = "Crea Squadra";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-plus display-1 text-primary"></i>
                        <h2 class="fw-bold">Nuova Squadra</h2>
                        <p class="text-muted">Inserisci i dettagli per registrare il team nel torneo</p>
                    </div>

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="TeamName" class="form-label fw-semibold">Nome della Squadra</label>
                                <input asp-for="TeamName" class="form-control form-control-lg bg-light border-0" placeholder="Esempio: AC Milan" />
                                <span asp-validation-for="TeamName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="City" class="form-label fw-semibold">Città</label>
                                <input asp-for="City" class="form-control bg-light border-0" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Country" class="form-label fw-semibold">Nazione</label>
                                <input asp-for="Country" class="form-control bg-light border-0" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ClubColors" class="form-label fw-semibold">Colori Sociali</label>
                                <input asp-for="ClubColors" class="form-control bg-light border-0" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ArrivalDateBellinzona" class="form-label fw-semibold">Data di Arrivo</label>
                                <input asp-for="ArrivalDateBellinzona" type="datetime-local" 
                                class="form-control form-control-sm border-0 bg-light" /> 
                            </div>

                            <div class="col-12"><hr class="my-3 opacity-25"></div>

                            <div class="mb-3">
                                <label asp-for="IdTournament"
                                        class="form-label small text-uppercase text-muted">Torneo</label>
                                <select asp-for="IdTournament" class="form-select form-select-sm border-0 bg-light"
                                        asp-items="ViewBag.IdTournament"></select>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="IdMezzo" class="form-label small text-uppercase text-muted">Mezzo di
                                        Trasporto</label>
                                        <select asp-for="IdMezzo" class="form-select form-select-sm border-0 bg-light"
                                                asp-items="ViewBag.IdMezzo">
                                            <option value="">-- Seleziona Mezzo --</option>
                                        </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="IdAccommodation"
                                            class="form-label small text-uppercase text-muted">Alloggio</label>
                                    <select asp-for="IdAccommodation" class="form-select form-select-sm border-0 bg-light"
                                            asp-items="ViewBag.IdAccommodation">
                                        <option value="">-- Seleziona Alloggio --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="IdUser" class="form-label small text-uppercase text-muted">Responsabile Account</label>
                                <select asp-for="IdUser" class="form-select form-select-sm border-0 bg-light"
                                        asp-items="ViewBag.IdUser"></select>
                            </div>
                        </div>

                        <div class="mt-5 d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow">Registra Squadra</button>
                            <a asp-action="Index" class="btn btn-link text-muted">Torna alla lista</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>