@model IEnumerable<Young_snakes.Models.Mezzo>

@{
    ViewData["Title"] = "Mezzi di Trasporto";
}

<div class="container py-4 text-dark">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h1 class="fw-light m-0 text-dark">Flotta <span class="fw-bold">Trasporti</span></h1>
            <p class="text-muted small mb-0">Gestisci i veicoli disponibili per gli spostamenti</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-2"></i>Nuovo Mezzo
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 small text-uppercase fw-bold text-muted">Tipo di Veicolo</th>
                        <th class="pe-4 py-3 border-0 small text-uppercase fw-bold text-muted text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3 text-center" style="width: 40px;">
                                        <i class="bi bi-bus-front-fill"></i>
                                    </div>
                                    <span class="fw-bold text-dark text-uppercase">@item.Veicolo</span>
                                </div>
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group btn-group-sm shadow-none">
                                    <a asp-action="Edit" asp-route-id="@item.IdMezzo" class="btn btn-white border-0 text-primary" title="Modifica">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.IdMezzo" class="btn btn-white border-0 text-secondary" title="Dettagli">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.IdMezzo" class="btn btn-white border-0 text-danger" title="Elimina">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>