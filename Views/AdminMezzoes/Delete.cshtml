@model Young_snakes.Models.Mezzo

@{
    ViewData["Title"] = "Elimina Mezzo";
}

<div class="container py-5 text-dark">
    <div class="row justify-content-center text-center">
        <div class="col-lg-5">
            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                <i class="bi bi-trash3 fs-1"></i>
            </div>
            
            <h2 class="fw-bold mb-3 text-dark">Sei sicuro?</h2>
            <p class="text-muted px-4">Stai per rimuovere il mezzo <strong>@Model.Veicolo</strong> dalla lista dei trasporti. Questa operazione è definitiva.</p>

            <form asp-action="Delete" class="mt-5">
                <input type="hidden" asp-for="IdMezzo" />
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold py-3 text-uppercase fs-6">Conferma ed Elimina</button>
                    <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none fw-bold mt-2">Torna alla lista</a>
                </div>
            </form>
        </div>
    </div>
</div>