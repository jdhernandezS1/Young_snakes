@model Young_snakes.Models.Mezzo

@{
    ViewData["Title"] = "Dettagli Mezzo";
}

<div class="container py-5 text-dark">
    <div class="row justify-content-center">
        <div class="col-lg-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-dark p-5">
                    <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-info-lg fs-1 text-white"></i>
                    </div>
                    <h6 class="text-white-50 text-uppercase small fw-bold">Scheda Tecnica</h6>
                    <h3 class="fw-bold text-white mb-0">@Model.Veicolo</h3>
                </div>
                <div class="card-body p-5 bg-white">
                    <div class="mb-4">
                        <p class="text-muted mb-1">ID Identificativo</p>
                        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-bold"># @Model.IdMezzo</span>
                    </div>
                    <div class="d-flex justify-content-center gap-3 pt-4 border-top">
                        <a asp-action="Edit" asp-route-id="@Model.IdMezzo" class="btn btn-dark px-4 rounded-pill fw-bold shadow-sm">Modifica</a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Indietro</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>