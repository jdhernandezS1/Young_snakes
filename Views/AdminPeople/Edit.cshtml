@model Person

@{
    ViewData["Title"] = "Modifica Membro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-light m-0">Modifica <span class="fw-bold">Membro</span></h2>
                    <p class="text-muted small">Aggiorna le informazioni personali e atletiche</p>
                </div>
                <a asp-controller="AdminTeams" asp-action="Edit" asp-route-id="@Model.IdTeam" class="btn btn-outline-secondary btn-sm rounded-pill">
                    <i class="bi bi-arrow-left me-1"></i> Annulla e torna al Team
                </a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-4 border-0 rounded-3 small"></div>
                    <input type="hidden" asp-for="IdPerson" />
                    <input type="hidden" asp-for="IdTeam" />

                    <div class="bg-dark p-4 p-md-5 text-white">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-auto text-center text-md-start">
                                <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg" style="width: 80px; height: 80px;">
                                    <i class="bi bi-person-gear display-6 text-white"></i>
                                </div>
                            </div>
                            <div class="col-md">
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label asp-for="FirstName" class="small text-uppercase opacity-75 fw-bold">Nome</label>
                                        <input asp-for="FirstName" class="form-control form-control-lg bg-white border-0 shadow-sm" placeholder="Nome" />
                                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="LastName" class="small text-uppercase opacity-75 fw-bold">Cognome</label>
                                        <input asp-for="LastName" class="form-control form-control-lg bg-white border-0 shadow-sm" placeholder="Cognome" />
                                        <span asp-validation-for="LastName" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4 p-md-5 bg-white">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <h6 class="text-primary fw-bold text-uppercase tracking-wider mb-4 border-bottom pb-2">
                                    <i class="bi bi-activity me-2"></i>Dati Atletici
                                </h6>
                                <div class="mb-3">
                                    <label asp-for="IdRole" class="form-label small text-muted text-uppercase">Ruolo nel Team</label>
                                    <select asp-for="IdRole" class="form-select bg-light border-0" asp-items="ViewBag.IdRole"></select>
                                </div>
                                <div class="row g-3">
                                    <div class="col-6">
                                        <label asp-for="Maglia" class="form-label small text-muted text-uppercase">N. Maglia</label>
                                        <input asp-for="Maglia" class="form-control bg-light border-0 text-center fw-bold fs-5" />
                                    </div>
                                    <div class="col-6">
                                        <label asp-for="Height" class="form-label small text-muted text-uppercase">Altezza (cm)</label>
                                        <input asp-for="Height" class="form-control bg-light border-0" />
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <label asp-for="BirthDate" class="form-label small text-muted text-uppercase">Data di Nascita</label>
                                    <input asp-for="BirthDate" type="date" class="form-control bg-light border-0" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h6 class="text-primary fw-bold text-uppercase tracking-wider mb-4 border-bottom pb-2">
                                    <i class="bi bi-envelope-at me-2"></i>Contatti
                                </h6>
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label small text-muted text-uppercase">Email Istituzionale</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-at"></i></span>
                                        <input asp-for="Email" class="form-control bg-light border-0" placeholder="esempio@email.com" />
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Phone" class="form-label small text-muted text-uppercase">Telefono</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-phone"></i></span>
                                        <input asp-for="Phone" class="form-control bg-light border-0" placeholder="+41 ..." />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-4 border-top d-flex justify-content-between align-items-center">
                            <p class="small text-muted m-0 d-none d-md-block">
                                <i class="bi bi-info-circle me-1"></i> Gli ID di sistema non sono modificabili.
                            </p>
                            <div class="d-flex gap-2 w-100 w-md-auto">
                                <button type="submit" class="btn btn-primary px-5 shadow-sm fw-bold">
                                    Salva Modifiche
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        border: 1px solid #0d6efd !important;
    }
    .tracking-wider { letter-spacing: 0.08em; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}