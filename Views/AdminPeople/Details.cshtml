@model Person

@{
    ViewData["Title"] = "Dettagli Membro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold m-0 text-dark">Scheda Membro</h2>
                <div class="btn-group shadow-sm">
                    <a asp-action="Edit" asp-route-id="@Model.IdPerson" class="btn btn-dark">
                        <i class="bi bi-pencil-square me-2"></i>Modifica
                    </a>
                    <a asp-controller="AdminTeams" asp-action="Edit" asp-route-id="@Model.IdTeam" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Torna al Team
                    </a>
                </div>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary p-4 text-white d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="bg-white rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="bi @(Model.Role?.RoleName == "Player" ? "bi-person-walking" : "bi-person-badge") display-6 text-primary"></i>
                        </div>
                        <div class="ms-4">
                            <h3 class="fw-bold mb-0">@Model.FirstName @Model.LastName</h3>
                            <span class="badge bg-white text-primary text-uppercase px-3 rounded-pill fw-bold">@Model.Role?.RoleName</span>
                        </div>
                    </div>
                    @if (Model.Maglia.HasValue)
                    {
                        <div class="text-end">
                            <div class="small opacity-75 text-uppercase">Numero Maglia</div>
                            <div class="display-4 fw-bold">#@Model.Maglia</div>
                        </div>
                    }
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h5 class="fw-bold border-bottom pb-2 mb-3">Informazioni Personali</h5>
                            
                            <div class="mb-3">
                                <label class="small text-muted text-uppercase d-block">Data di Nascita</label>
                                <span class="fw-semibold fs-5">@(Model.BirthDate?.ToString("dd MMMM yyyy") ?? "-")</span>
                            </div>

                            <div class="mb-3">
                                <label class="small text-muted text-uppercase d-block">Altezza</label>
                                <span class="fw-semibold fs-5">@(Model.Height > 0 ? $"{Model.Height} cm" : "-")</span>
                            </div>

                            <div class="mb-3">
                                <label class="small text-muted text-uppercase d-block">Squadra Corrente</label>
                                <span class="fw-semibold fs-5 text-primary">@Model.Team?.TeamName</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold border-bottom pb-2 mb-3">Contatti</h5>
                            
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-3 p-2 me-3">
                                    <i class="bi bi-envelope text-primary"></i>
                                </div>
                                <div>
                                    <label class="small text-muted text-uppercase d-block">Email</label>
                                    <span class="fw-semibold">@(Model.Email ?? "Nessuna email")</span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-3 p-2 me-3">
                                    <i class="bi bi-telephone text-primary"></i>
                                </div>
                                <div>
                                    <label class="small text-muted text-uppercase d-block">Telefono</label>
                                    <span class="fw-semibold">@(Model.Phone ?? "Nessun telefono")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top">
                        <div class="row text-center text-md-start">
                            <div class="col-md-4">
                                <small class="text-muted text-uppercase d-block">ID Membro</small>
                                <code class="fw-bold">#@Model.IdPerson</code>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted text-uppercase d-block">ID Ruolo</small>
                                <code class="fw-bold text-dark">#@Model.IdRole</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>