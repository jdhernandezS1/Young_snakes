@model IEnumerable<Young_snakes.Models.Auth.ApplicationUser>

<div class="container shadow p-4 mt-4 bg-white">
    <h2 class="text-dark">Gestione Utenti Registrati</h2>
    <table class="table table-hover mt-3">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Stato Email</th>
                <th>Team</th>
                <th>Azioni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td><strong>@user.UserName</strong></td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.EmailConfirmed) {
                            <span class="badge bg-success">Confermata</span>
                        } else {
                            <span class="badge bg-warning">In attesa</span>
                        }
                    </td>
                    <td>@(user.Team?.TeamName ?? "Nessun Team")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Modifica</a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Elimina</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>