@model Young_snakes.Models.DietaryTag

@{
    ViewData["Title"] = "Crea Etichetta";
}

<div class="container py-5 text-dark">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-light m-0">Aggiungi <span class="fw-bold">Etichetta</span></h2>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">Torna alla lista</a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-4 border-0 rounded-3 small"></div>
                    
                    <div class="bg-dark p-4 p-md-5 text-white">
                        <div class="mb-4 text-center">
                            <i class="bi bi-tag-fill display-4 text-primary opacity-75"></i>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TagName" class="small text-uppercase fw-bold text-white-50 d-block mb-1">Nome Dieta</label>
                            <input asp-for="TagName" class="form-control form-control-lg bg-white border-0 shadow-none" placeholder="Es. Senza Glutine" />
                            <span asp-validation-for="TagName" class="text-danger small"></span>
                        </div>
                        <div class="mb-0">
                            <label asp-for="TagType" class="small text-uppercase fw-bold text-white-50 d-block mb-1">Tipo di Restrizione</label>
                            <select asp-for="TagType" class="form-select form-select-lg bg-white border-0 shadow-none text-dark">
                                <option value="" disabled selected>-- Select Type --</option>
                                <option value="Allergy">Allergy</option>
                                <option value="Diet">Diet</option>
                            </select>
                            <span asp-validation-for="TagType" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="card-body p-4 bg-white d-grid">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3 text-uppercase fs-6">
                            Crea Etichetta
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>