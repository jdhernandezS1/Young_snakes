@model Young_snakes.Models.DietaryTag

@{
    ViewData["Title"] = "Elimina";
}

<div class="container py-5 text-dark text-center">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                <i class="bi bi-x-circle fs-1"></i>
            </div>
            
            <h2 class="fw-bold mb-3">Conferma Eliminazione</h2>
            <p class="text-muted mb-4">Sei sicuro di voler rimuovere l'etichetta <strong>@Model.TagName</strong>?</p>

            <form asp-action="Delete">
                <input type="hidden" asp-for="IdTag" />
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold py-3 text-uppercase fs-6">Elimina Definitivamente</button>
                    <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">No, torna alla lista</a>
                </div>
            </form>
        </div>
    </div>
</div>