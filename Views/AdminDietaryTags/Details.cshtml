@model Young_snakes.Models.DietaryTag

@{
    ViewData["Title"] = "Dettagli";
}

<div class="container py-5 text-dark text-center">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-dark p-5">
                    <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center shadow mb-3" style="width: 70px; height: 70px;">
                        <i class="bi bi-journal-text fs-2 text-white"></i>
                    </div>
                    <h3 class="fw-bold text-white m-0">@Model.TagName</h3>
                </div>
                <div class="card-body p-5 bg-white">
                    <p class="text-uppercase small text-muted fw-bold mb-1">Tipo Restrizione</p>
                    <h4 class="text-dark mb-4 fw-light">@Model.TagType</h4>
                    
                    <div class="d-flex justify-content-center gap-2 border-top pt-4">
                        <a asp-action="Edit" asp-route-id="@Model.IdTag" class="btn btn-dark px-4 rounded-pill fw-bold">Modifica</a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Indietro</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>