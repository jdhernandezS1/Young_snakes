@model Young_snakes.Models.DietaryTag

@{
    ViewData["Title"] = "Details";
}


<div>
    <h4>Alergeni e Diete</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            DIETA: 
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TagName)
        </dd>
        <dt class = "col-sm-2">
            TIPO: 
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TagType)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.IdTag">Edit</a> |
    <a asp-action="Index">Torna a la lista</a>
</div>
