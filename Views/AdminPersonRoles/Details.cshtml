@model Young_snakes.Models.PersonRole

@{
    ViewData["Title"] = "Dettagli Ruolo";
}

<div class="container py-5 text-dark">
    <div class="row justify-content-center">
        <div class="col-lg-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-dark">
                <div class="bg-primary p-5 text-white">
                    <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg mb-3" style="width: 70px; height: 70px;">
                        <i class="bi bi-person-check fs-2 text-primary"></i>
                    </div>
                    <h6 class="text-white-50 text-uppercase small fw-bold mb-1">Dettaglio Sistema</h6>
                    <h3 class="fw-bold mb-0">@Model.RoleName</h3>
                </div>
                <div class="card-body p-5 bg-white">
                    <div class="mb-4">
                        <p class="text-muted small text-uppercase fw-bold mb-1">ID Interno</p>
                        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-bold">ID: @Model.IdRole</span>
                    </div>
                    <div class="d-flex justify-content-center gap-2 pt-4 border-top">
                        <a asp-action="Edit" asp-route-id="@Model.IdRole" class="btn btn-dark px-4 rounded-pill fw-bold">Modifica</a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Chiudi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>