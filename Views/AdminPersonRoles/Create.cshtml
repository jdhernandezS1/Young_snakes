@model Young_snakes.Models.PersonRole

@{
    ViewData["Title"] = "Crea Ruolo";
}

<div class="container py-5 text-dark">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                <h2 class="fw-light m-0 text-dark text-uppercase tracking-tight">Nuovo <span class="fw-bold">Ruolo</span></h2>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Indietro</a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-4 border-0 rounded-3 small"></div>
                    
                    <div class="bg-dark p-4 p-md-5 text-white">
                        <div class="mb-0 text-center text-md-start">
                            <label asp-for="RoleName" class="small text-uppercase fw-bold text-white-50 d-block mb-2">Nome della Posizione</label>
                            <input asp-for="RoleName" class="form-control form-control-lg bg-white border-0 shadow-none fw-bold" placeholder="Es. Allenatore, Capitano..." />
                            <span asp-validation-for="RoleName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="card-body p-4 bg-white d-grid">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3 text-uppercase fs-6">
                            Salva Ruolo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>