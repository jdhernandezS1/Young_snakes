@model IEnumerable<Young_snakes.Models.Tournament>

@{
    ViewData["Title"] = "Gestione Tornei";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h1 class="fw-light m-0">Gestione <span class="fw-bold">Tornei</span></h1>
            <p class="text-muted small mb-0">Configura le competizioni e monitora le iscrizioni</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Nuovo Torneo
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 small text-uppercase fw-bold text-muted">Competizione</th>
                        <th class="py-3 border-0 small text-uppercase fw-bold text-muted text-center">Anno</th>
                        <th class="py-3 border-0 small text-uppercase fw-bold text-muted text-center">Rosa (Min/Max)
                        </th>
                        <th class="py-3 border-0 small text-uppercase fw-bold text-muted text-center">Extra Fee</th>
                        <th class="py-3 border-0 small text-uppercase fw-bold text-muted text-center">Stato</th>
                        <th class="pe-4 py-3 border-0 small text-uppercase fw-bold text-muted text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3">
                                        <i class="bi bi-trophy-fill fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.TournamentName</div>
                                        <div class="text-muted small">@item.CategoryName</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border fw-medium px-3 py-2 rounded-pill">
                                    @item.TournamentYear.Year
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="small fw-bold text-dark">@item.MinPlayers - @item.MaxPlayers</div>
                                <div class="text-muted" style="font-size: 0.7rem;">GIOCATORI</div>
                            </td>
                            <td class="text-center">
                                <div class="fw-bold text-primary">€@item.ExtraPlayerFee</div>
                            </td>
                            <td class="text-center">
                                @if (item.IsOpen)
                                {
                                    <span
                                        class="badge bg-success bg-opacity-10 text-success border-success border-opacity-25 px-3 py-2 rounded-pill">
                                        <i class="bi bi-unlock-fill me-1"></i>Aperto
                                    </span>
                                }
                                else
                                {
                                    <span
                                        class="badge bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 px-3 py-2 rounded-pill">
                                        <i class="bi bi-lock-fill me-1"></i>Chiuso
                                    </span>
                                }
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group btn-group-sm shadow-none">
                                    <a asp-controller="AdminTeams" asp-action="Index" asp-route-id="@item.IdTournament"
                                           class="btn btn-outline-primary border-0 bg-primary bg-opacity-10 px-3"
                                           title="Squadre">
                                        <i class="bi bi-people-fill me-1"></i> Squadre
                                    </a>
                                    <div class="vr mx-1 opacity-25"></div>
                                    <a asp-action="Edit" asp-route-id="@item.IdTournament"
                                           class="btn btn-white border-0 text-primary" title="Modifica">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.IdTournament"
                                           class="btn btn-white border-0 text-secondary" title="Dettagli">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.IdTournament"
                                           class="btn btn-white border-0 text-danger" title="Elimina">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 bg-light">
                <i class="bi bi-clipboard-x display-1 text-muted opacity-25"></i>
                <p class="mt-3 mb-0 text-muted">Nessun torneo configurato nel sistema.</p>
            </div>
        }
    </div>
</div>